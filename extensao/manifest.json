{
  "manifest_version": 3,
  "name": "Afiliado Analytics",
  "version": "1.0.0",
  "description": "Capture e copie seus tokens de sessão do Mercado Livre e Amazon para suas automações Afiliado Analytics.",
  "permissions": [
    "cookies",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.mercadolivre.com.br/*",
    "https://mercadolivre.com.br/*",
    "https://www.amazon.com.br/*",
    "https://amazon.com.br/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}